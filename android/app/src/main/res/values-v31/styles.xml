<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ (API 31+) uses the new SplashScreen API which auto-shows
         the app's launcher icon. Override it here to suppress the icon so the
         app launches straight into the black calculator background with no
         visible splash image. -->
    <style name="LaunchTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/transparent_splash_icon</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/black</item>
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
    </style>
</resources>
